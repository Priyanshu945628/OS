#!/bin/bash
# =====================================================================
# AEGIS OS - SECURE WINE / WINDOWS APPS SANDBOXING SCRIPT
# =====================================================================

set -euo pipefail

# Visual headers
echo -e "\033[1;36m====================================================\033[0m"
echo -e "\033[1;36m             AEGIS OS - WINE SANDBOX SETUP          \033[0m"
echo -e "\033[1;36m====================================================\033[0m"

# Running as regular user is required for Wine prefixes (Wine should never run as root)
if [ "$EUID" -eq 0 ]; then
    echo -e "\033[1;31m[-] Error: Do NOT run Wine sandboxing script as root. Run it as your normal user.\033[0m"
    exit 1
fi

echo -e "\033[1;34m[*] Choose Windows App runtime environment:\033[0m"
echo -e "    1) Secure WinePrefix (Native Wine, but completely isolated from your filesystem)"
echo -e "    2) Bottles (Flatpak-based GUI manager - Recommended for absolute container sandboxing)"
read -p "Select option [1-2] (default 2): " choice

choice=${choice:-2}

if [ "$choice" = "2" ]; then
    echo -e "\033[1;34m[*] Verifying Flatpak availability...\033[0m"
    if ! command -v flatpak &> /dev/null; then
        echo -e "\033[1;31m[-] Error: Flatpak is missing. Run as root: pacman -S flatpak\033[0m"
        exit 1
    fi
    
    echo -e "\033[1;34m[*] Adding Flathub repository...\033[0m"
    flatpak remote-add --user --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo
    
    echo -e "\033[1;34m[*] Installing Bottles sandboxed runner... (This may take a minute)\033[0m"
    flatpak install --user -y flathub com.usebottles.bottles
    
    echo -e "\033[1;32m[+] Bottles installed successfully!\033[0m"
    echo -e "\033[1;32m[+] Run Bottles from the applications menu to manage and containerize your Windows apps (.exe / .msi).\033[0m"

else
    # Option 1: Native Wine prefix with Z: drive removed
    PREFIX_PATH="$HOME/.local/share/wineprefixes/secure-sandbox"
    echo -e "\033[1;34m[*] Initializing secure native WinePrefix at: $PREFIX_PATH\033[0m"
    
    export WINEPREFIX="$PREFIX_PATH"
    export WINEARCH="win64"
    
    # Initialize the prefix silently
    wineboot -i
    
    # CRITICAL SECURITY STEP: Remove Z: drive mapping (which maps to root / of the Linux host)
    # This prevents Windows executables from crawling the Linux filesystem or encrypting host folders.
    echo -e "\033[1;34m[*] Stripping filesystem mount mappings (removing Z: drive)... \033[0m"
    if [ -L "$PREFIX_PATH/dosdevices/z:" ]; then
        rm -f "$PREFIX_PATH/dosdevices/z:"
        echo -e "\033[1;32m[+] Z: drive linkage removed successfully.\033[0m"
    else
        echo -e "\033[1;33m[!] Warning: Z: drive link not found, system may already be isolated.\033[0m"
    fi

    # Create launch wrapper helper
    WRAPPER_BIN="$HOME/.local/bin/aegis-wine"
    mkdir -p "$HOME/.local/bin"
    
    cat << 'EOF' > "$WRAPPER_BIN"
#!/bin/bash
export WINEPREFIX="$HOME/.local/share/wineprefixes/secure-sandbox"
export WINEARCH="win64"
if [ "$#" -eq 0 ]; then
    echo "Usage: aegis-wine <path-to-windows-exe>"
    exit 1
fi
# Executing within prefix
wine "$@"
EOF
    chmod +x "$WRAPPER_BIN"

    echo -e "\033[1;32m[+] Secure Wine wrapper script created at: $WRAPPER_BIN\033[0m"
    echo -e "\033[1;32m[+] You can now run your Windows apps securely using: aegis-wine file.exe\033[0m"
fi

echo -e "\033[1;36m====================================================\033[0m"
