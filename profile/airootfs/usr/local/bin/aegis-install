#!/bin/bash
# =====================================================================
# AEGIS OS - LUKS2 ENCRYPTED INSTALLER SCRIPT
# =====================================================================

set -euo pipefail

# Visual styling
echo -e "\033[1;36m====================================================\033[0m"
echo -e "\033[1;36m             AEGIS OS - ENCRYPTED INSTALLER         \033[0m"
echo -e "\033[1;36m====================================================\033[0m"

# Root check
if [ "$EUID" -ne 0 ]; then
    echo -e "\033[1;31m[-] Error: The installer must be run as root.\033[0m"
    exit 1
fi

echo -e "\033[1;33m[!] WARNING: This installer will partition and format storage devices.\033[0m"
echo -e "\033[1;33m[!] Ensure you have backed up any critical data before proceeding.\033[0m"
echo -e ""

# List drives
echo -e "\033[1;34m[*] Available Storage Devices:\033[0m"
lsblk -dno NAME,SIZE,MODEL | grep -v "loop" || true
echo -e ""

read -p "Enter the target device to install AegisOS (e.g., sda, nvme0n1): " DEV_NAME

DEV_PATH="/dev/$DEV_NAME"

if [ ! -b "$DEV_PATH" ]; then
    echo -e "\033[1;31m[-] Error: Device $DEV_PATH is invalid or does not exist.\033[0m"
    exit 1
fi

echo -e "\033[1;33m[!] You selected: $(lsblk -dno MODEL,SIZE "$DEV_PATH")\033[0m"
read -p "Are you absolutely sure you want to completely WIPE this drive? (y/N): " confirm
if [[ ! "$confirm" =~ ^[yY]$ ]]; then
    echo -e "Installation cancelled."
    exit 0
fi

# 1. Partitioning (GPT)
# EFI Partition: 1GB, Crypt Root: Rest of drive
echo -e "\033[1;34m[*] Creating partition layout (GPT)... \033[0m"
parted -s "$DEV_PATH" mklabel gpt
parted -s "$DEV_PATH" mkpart primary fat32 1MiB 1025MiB
parted -s "$DEV_PATH" set 1 esp on
parted -s "$DEV_PATH" mkpart primary ext4 1025MiB 100%

# Determine partition names (nvme0n1p1/sda1 style)
if [[ "$DEV_NAME" =~ "nvme" ]]; then
    PART_EFI="${DEV_PATH}p1"
    PART_ROOT="${DEV_PATH}p2"
else
    PART_EFI="${DEV_PATH}1"
    PART_ROOT="${DEV_PATH}2"
fi

# 2. LUKS2 Encryption setup
echo -e "\033[1;34m[*] Preparing LUKS2 Encrypted Volume on $PART_ROOT...\033[0m"
echo -e "\033[1;34m[*] Please enter a strong decryption passphrase:\033[0m"

cryptsetup luksFormat --type luks2 --pbkdf argon2id "$PART_ROOT"

echo -e "\033[1;34m[*] Opening encrypted container...\033[0m"
cryptsetup open "$PART_ROOT" aegis_root

# 3. Formatting
echo -e "\033[1;34m[*] Formatting filesystems...\033[0m"
mkfs.vfat -F 32 -n "AEGIS_EFI" "$PART_EFI"
mkfs.ext4 -L "AEGIS_ROOT" /dev/mapper/aegis_root

# 4. Mount
echo -e "\033[1;34m[*] Mounting target partitions...\033[0m"
mount /dev/mapper/aegis_root /mnt
mkdir -p /mnt/boot
mount "$PART_EFI" /mnt/boot

# 5. Pacstrap base installation
echo -e "\033[1;34m[*] Bootstrapping AegisOS (pacstrap)... This will install the base system + security modules.\033[0m"
pacstrap -K /mnt base linux-hardened linux-hardened-headers grub efibootmgr networkmanager sway waybar alacritty rofi-wayland tor macchanger apparmor firejail dnscrypt-proxy nftables flatpak waydroid lxc dnsmasq wine

# 6. Fstab generation
echo -e "\033[1;34m[*] Generating fstab registry...\033[0m"
genfstab -U /mnt >> /mnt/etc/fstab

# 7. Configure Chroot environment
echo -e "\033[1;34m[*] Configuring bootloader, locale, and user details inside chroot...\033[0m"

# Get partition UUID for crypttab/GRUB configuration
UUID_CRYPT=$(blkid -s UUID -o value "$PART_ROOT")

# Create configure chroot script
cat << EOF > /mnt/tmp/aegis_chroot_setup.sh
#!/bin/bash
set -e
echo "aegis-os" > /etc/hostname
echo "127.0.0.1 localhost" >> /etc/hosts
echo "::1       localhost" >> /etc/hosts
echo "127.0.1.1 aegis-os.localdomain aegis-os" >> /etc/hosts

# Enforce UTF-8 Locale
echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen
locale-gen
echo "LANG=en_US.UTF-8" > /etc/locale.conf

# Setup Systemd Hooks for Cryptsetup in Initramfs
sed -i 's/^HOOKS=(.*/HOOKS=(base udev autodetect modconf kms keyboard keymap consolefont block encrypt filesystems fsck)/' /etc/mkinitcpio.conf
mkinitcpio -P

# Setup GRUB with LUKS decryption
sed -i 's|^GRUB_CMDLINE_LINUX_DEFAULT=.*|GRUB_CMDLINE_LINUX_DEFAULT="loglevel=3 quiet cryptdevice=UUID=$UUID_CRYPT:aegis_root root=/dev/mapper/aegis_root apparmor=1 lsm=landlock,lockdown,yama,integrity,apparmor,bpf"|' /etc/default/grub

grub-install --target=x86_64-efi --efi-directory=/boot --bootloader-id=AegisOS
grub-mkconfig -o /boot/grub/grub.cfg

# Enable key services
systemctl enable NetworkManager.service
systemctl enable apparmor.service
systemctl enable nftables.service

# Setup users
echo -e "\n[*] Set root password:"
passwd

read -p "Enter username for secure user: " sec_user
useradd -m -G wheel,video,audio,optical,storage -s /bin/bash "\$sec_user"
echo -e "\n[*] Set password for \$sec_user:"
passwd "\$sec_user"

# Enable wheel sudo privileges safely
echo "%wheel ALL=(ALL:ALL) ALL" > /etc/sudoers.d/10-wheel-privs
EOF

# Execute setup
chmod +x /mnt/tmp/aegis_chroot_setup.sh
arch-chroot /mnt /tmp/aegis_chroot_setup.sh
rm -f /mnt/tmp/aegis_chroot_setup.sh

# Unmount
echo -e "\033[1;34m[*] Unmounting filesystems and closing container...\033[0m"
umount -R /mnt
cryptsetup close aegis_root

echo -e "\033[1;32m[+] SUCCESS! AegisOS has been installed on $DEV_PATH.\033[0m"
echo -e "\033[1;32m[+] Reboot your system, pull the USB drive, and boot into AegisOS.\033[0m"
echo -e "\033[1;36m====================================================\033[0m"
